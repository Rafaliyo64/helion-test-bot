# Token de tu bot de Discord (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=tu_token_aqui

# Qué IA usa el bot: "groq" (nube, gratis, recomendado en hostings ligeros
# como Railway) u "ollama" (100% local, sin nube, pero necesita RAM/CPU
# de sobra en la MISMA máquina donde corre el bot - no recomendado en
# hostings gratuitos/ligeros).
AI_BACKEND=groq

# --- Si usas AI_BACKEND=groq ---
# API key de Groq (console.groq.com) - GRATIS, sin tarjeta
GROQ_API_KEY=tu_api_key_aqui
GROQ_MODEL=llama-3.3-70b-versatile

# --- Si usas AI_BACKEND=ollama (requiere Ollama corriendo en el mismo host) ---
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_HOST=http://localhost:11434

# Fichero de personalidad de Helion (editable sin tocar código)
PERSONALITY_FILE=helion_personalidad.txt

# ID del canal donde el bot debe responder SIEMPRE sin necesidad de mencionarlo
LISTEN_CHANNEL_ID=1526126453069053972

# Nombre del rol que además de administradores puede activar la moderación
# (déjalo vacío si solo quieres que lo usen quienes tengan permiso de Discord de kick/ban)
MOD_ROLE_NAME=

# IDs de los usuarios que reciben el DM con los botones de Aviso/Expulsar/Banear
# cuando el bot detecta actividad sospechosa
MOD_USER_IDS=1505978108128530604,1525991928439636099

# Fichero con una mala palabra por línea (opcional). Si no existe, se usa
# una lista básica por defecto.
BAD_WORDS_FILE=malas_palabras.txt

# Modelo de Whisper para transcribir voz: tiny (más rápido, menos preciso)
# base, small, medium (más preciso, más lento/pesado)
WHISPER_MODEL=base

# Segundos que graba por ciclo antes de transcribir en la llamada de voz
VOICE_RECORD_SECONDS=5

# Voz de Helion al hablar: "gtts" (nube, gratis, funciona ya) o "piper"
# (100% local, requiere instalar el binario piper y un modelo .onnx)
TTS_BACKEND=gtts
PIPER_BINARY=piper
PIPER_VOICE_MODEL=

# Anuncios de YouTube (déjalo vacío para desactivar esta función)
YOUTUBE_CHANNEL_ID=
ANNOUNCE_CHANNEL_ID=
YOUTUBE_CHECK_INTERVAL=600
